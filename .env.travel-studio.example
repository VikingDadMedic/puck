# =============================================================================
# Travel Composition Studio — Docker environment
# Copy to .env.travel-studio.local and fill in real values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# Postgres (shared by Supabase services + Directus)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Supabase — core settings
# Generate a JWT secret (>= 32 chars) and derive anon/service keys from it.
# See: https://supabase.com/docs/guides/self-hosting#api-keys
# ---------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTYyMDAwMDAwMCwiZXhwIjoxOTIwMDAwMDAwfQ.PLACEHOLDER_GENERATE_REAL_KEY
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjIwMDAwMDAwLCJleHAiOjE5MjAwMDAwMDB9.PLACEHOLDER_GENERATE_REAL_KEY

# ---------------------------------------------------------------------------
# Supabase — GoTrue (auth)
# ---------------------------------------------------------------------------
GOTRUE_SITE_URL=http://localhost:3001
GOTRUE_URI_ALLOW_LIST=http://localhost:3001
GOTRUE_JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_EXP=3600
GOTRUE_DB_DRIVER=postgres
GOTRUE_DB_DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?sslmode=disable
GOTRUE_API_HOST=0.0.0.0
GOTRUE_API_PORT=9999
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMTP_ADMIN_EMAIL=admin@travel-studio.local
GOTRUE_DISABLE_SIGNUP=false

# ---------------------------------------------------------------------------
# Supabase — Realtime
# ---------------------------------------------------------------------------
REALTIME_DB_HOST=db
REALTIME_DB_PORT=5432
REALTIME_DB_USER=postgres
REALTIME_DB_PASSWORD=${POSTGRES_PASSWORD}
REALTIME_DB_NAME=postgres
REALTIME_DB_SSL=false
REALTIME_PORT=4000
REALTIME_SECRET_KEY_BASE=your-realtime-secret-key-base-at-least-64-chars-long-change-me-in-production

# ---------------------------------------------------------------------------
# Supabase — Storage
# ---------------------------------------------------------------------------
STORAGE_BACKEND=file
STORAGE_FILE_BACKEND_PATH=/var/lib/storage
STORAGE_ANON_KEY=${ANON_KEY}
STORAGE_SERVICE_KEY=${SERVICE_ROLE_KEY}
STORAGE_POSTGREST_URL=http://kong:8000/rest/v1
STORAGE_DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?sslmode=disable
STORAGE_JWT_SECRET=${JWT_SECRET}

# ---------------------------------------------------------------------------
# Supabase — Studio (admin dashboard)
# ---------------------------------------------------------------------------
STUDIO_PG_META_URL=http://kong:8000/pg
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
STUDIO_DEFAULT_ORGANIZATION=Travel Studio
STUDIO_DEFAULT_PROJECT=travel-studio

# ---------------------------------------------------------------------------
# Kong — API gateway
# ---------------------------------------------------------------------------
KONG_DATABASE=off
KONG_DECLARATIVE_CONFIG=/var/lib/kong/kong.yml
KONG_DNS_ORDER=LAST,A,CNAME
KONG_PLUGINS=request-transformer,cors,key-auth,acl

# ---------------------------------------------------------------------------
# Directus — headless CMS
# ---------------------------------------------------------------------------
DIRECTUS_KEY=a-random-directus-key-replace-me
DIRECTUS_SECRET=a-random-directus-secret-replace-me
DIRECTUS_DB_CLIENT=pg
DIRECTUS_DB_HOST=db
DIRECTUS_DB_PORT=5432
DIRECTUS_DB_DATABASE=directus
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=directus
DIRECTUS_ADMIN_EMAIL=admin@travel-studio.local
DIRECTUS_ADMIN_PASSWORD=change-me-in-production
DIRECTUS_WEBSOCKETS_ENABLED=true
DIRECTUS_CACHE_ENABLED=true
DIRECTUS_CACHE_STORE=redis
DIRECTUS_REDIS_HOST=redis
DIRECTUS_REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Travel Studio — Next.js app
# ---------------------------------------------------------------------------
# API keys for third-party data feeds (SerpAPI, Pexels, Unsplash, Mapbox)
SERP_API_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_APPLICATION_ID=
MAPBOX_ACCESS_TOKEN=
PUBLIC_MAPBOX_TOKEN=
# URLs for backend services (resolved via Docker network)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
DIRECTUS_URL=http://directus:8055
