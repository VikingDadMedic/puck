{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voyagersocial.io/schemas/common/money.schema.json",
  "title": "Money",
  "type": "object",
  "required": ["amount", "currency"],
  "properties": {
    "amount": { "type": "number" },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 4217 code preferred"
    }
  },
  "additionalProperties": false
}
